{
  "openapi": "3.1.0",
  "info": {
    "title": "Risk Guardrail API",
    "version": "0.1.0",
    "description": "Contract-of-record baseline for the Risk Guardrail System."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "system",
      "description": "Health and metadata endpoints."
    },
    {
      "name": "ingestion",
      "description": "Canonical event ingestion endpoints."
    },
    {
      "name": "admin",
      "description": "Administrative and reporting endpoints."
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["system"],
        "summary": "Health check",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service health response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/fills:ingest": {
      "post": {
        "tags": ["ingestion"],
        "summary": "Ingest canonical fill events",
        "operationId": "ingestFills",
        "description": "Authenticated ingestion placeholder for canonical fill events.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Ingestion accepted placeholder response"
          },
          "401": {
            "description": "Missing or invalid authentication token"
          },
          "403": {
            "description": "Tenant scope violation or insufficient permissions"
          }
        }
      }
    },
    "/v1/accounts:snapshot": {
      "post": {
        "tags": ["ingestion"],
        "summary": "Ingest canonical account snapshots",
        "operationId": "ingestAccountSnapshots",
        "description": "Authenticated account snapshot ingestion with duplicate-safe counting using PostgreSQL-backed persistence. DB-authoritative idempotency key: tenant_id + connector_id + source_account_id + event_ts.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Snapshot ingestion accepted with persistence counters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountSnapshotIngestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload or snapshot content"
          },
          "401": {
            "description": "Missing or invalid authentication token"
          },
          "403": {
            "description": "Tenant scope violation or insufficient permissions"
          },
          "503": {
            "description": "Persistence unavailable: PostgreSQL connection or repository wiring not available"
          }
        }
      }
    },
    "/v1/risk:evaluate": {
      "post": {
        "tags": ["ingestion"],
        "summary": "Evaluate risk state from account snapshot",
        "operationId": "evaluateRisk",
        "description": "Authenticated risk evaluation for a canonical account snapshot. Status thresholds: warning at loss_ratio >= 0.8 and breached at loss_ratio >= 1.0. Trading-day boundary defaults to America/Chicago at 17:00. Persistence linkage to snapshot/risk tables is best-effort in this slice.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RiskEvaluationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Risk evaluation completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RiskEvaluationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload or invalid canonical snapshot"
          },
          "401": {
            "description": "Missing or invalid authentication token"
          },
          "403": {
            "description": "Tenant scope violation or insufficient permissions"
          }
        }
      }
    },
    "/v1/admin/accounts/{accountId}/unlock": {
      "post": {
        "tags": ["admin"],
        "summary": "Unlock an account",
        "operationId": "unlockAccount",
        "description": "Authenticated admin placeholder for unlock operations.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Unlock accepted placeholder response"
          },
          "401": {
            "description": "Missing or invalid authentication token"
          },
          "403": {
            "description": "Insufficient role or tenant scope violation"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status", "service"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok"]
          },
          "service": {
            "type": "string"
          }
        }
      },
      "AccountSnapshotIngestResponse": {
        "type": "object",
        "required": [
          "status",
          "tenant_id",
          "accepted_count",
          "total_count",
          "persisted_count",
          "duplicate_count"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["accepted"]
          },
          "tenant_id": {
            "type": "string"
          },
          "accepted_count": {
            "type": "integer",
            "minimum": 0
          },
          "total_count": {
            "type": "integer",
            "minimum": 0
          },
          "persisted_count": {
            "type": "integer",
            "minimum": 0
          },
          "duplicate_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "RiskEvaluationRequest": {
        "type": "object",
        "required": ["snapshot"],
        "properties": {
          "snapshot": {
            "type": "object",
            "required": [
              "tenant_id",
              "connector_id",
              "source_account_id",
              "event_ts",
              "current_balance",
              "daily_pnl",
              "account_currency",
              "trading_is_disabled"
            ],
            "properties": {
              "tenant_id": { "type": "string" },
              "connector_id": { "type": "string" },
              "source_account_id": { "type": "string" },
              "event_ts": { "type": "string", "format": "date-time" },
              "current_balance": { "type": "string" },
              "daily_pnl": { "type": "string" },
              "daily_net_loss_limit": { "type": "string" },
              "account_currency": { "type": "string" },
              "trading_is_disabled": { "type": "boolean" }
            }
          }
        }
      },
      "RiskEvaluationResponse": {
        "type": "object",
        "required": [
          "status",
          "tenant_id",
          "risk_status",
          "trading_locked",
          "trading_day",
          "loss_ratio"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["evaluated"]
          },
          "tenant_id": {
            "type": "string"
          },
          "risk_status": {
            "type": "string",
            "enum": ["active", "warning", "breached"]
          },
          "trading_locked": {
            "type": "boolean"
          },
          "trading_day": {
            "type": "string",
            "format": "date"
          },
          "loss_ratio": {
            "type": ["number", "null"]
          }
        }
      }
    }
  }
}
